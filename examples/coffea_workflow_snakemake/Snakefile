"""
Snakemake workflow replicating the coffea-workflow render() pipeline.

Rules
-----
make_fileset      Build the fileset dict and write it as JSON.
split_fileset     (checkpoint) Split the fileset into per-chunk JSON files.
                  Declared as a checkpoint so Snakemake re-evaluates the DAG
                  once the number of chunks is known.
run_chunk_analysis  Analyse one chunk.  Always succeeds (Option A): both the
                  payload and a .status file are written regardless of whether
                  the physics job succeeded or failed.  Failed chunks are
                  skipped during merging; the workflow continues.
merge_analysis    Accumulate all chunk payloads into a single merged result.
make_plot         Produce the final plot from the merged result.
"""

from pathlib import Path

configfile: "config.yaml"


# result of analysis
rule all:
    input: "results/plots/met.png"


rule make_fileset:
    output: "results/fileset.json"
    params:
        builder=config["fileset_builder"],
        builder_params=config.get("fileset_builder_params", {}),
    script: "scripts/make_fileset.py"


checkpoint split_fileset:
    input: "results/fileset.json"
    output: directory("results/chunks/")
    params:
        strategy=config.get("strategy"),
        percentage=config.get("percentage"),
        datasets=config.get("datasets"),
    script: "scripts/split_fileset.py"


rule run_chunk_analysis:
    input:
        chunk="results/chunks/{chunk_id}.json",
    output:
        payload="results/chunk_results/{chunk_id}.pkl",
        status="results/chunk_results/{chunk_id}.status",
    params:
        builder=config["analysis_builder"],
        builder_params=config.get("analysis_builder_params", {}),
    resources:
        mem_mb=8000,
        runtime=120,
    script: "scripts/run_chunk_analysis.py"


import re

def _chunk_ids(wildcards):
    co = checkpoints.split_fileset.get(**wildcards)
    ids, = glob_wildcards(str(Path(co.output[0]) / "{id}.json"))

    return [i for i in ids if re.fullmatch(r"chunk_\d+", i)]


rule merge_analysis:
    input:
        payloads=lambda wc: expand("results/chunk_results/{id}.pkl",  id=_chunk_ids(wc)),
        statuses=lambda wc: expand("results/chunk_results/{id}.status", id=_chunk_ids(wc)),
    output: "results/analysis/merged.pkl"
    params:
        builder_key=config["analysis_builder"],
    resources:
        mem_mb=4000,
        runtime=30,
    script: "scripts/merge_analysis.py"


rule make_plot:
    input: "results/analysis/merged.pkl"
    output: "results/plots/met.png"
    params:
        builder=config["plot_builder"],
        builder_params=config.get("plot_builder_params", {}),
    resources:
        mem_mb=2000,
        runtime=10,
    script: "scripts/make_plot.py"
